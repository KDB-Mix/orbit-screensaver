; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Orbit Screensaver"
run/main_scene="uid://cnygno47jx4ec"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/show_image=false
boot_splash/use_filter=false
config/icon="res://icon.svg"

[autoload]

ConfigSave="*uid://bihndaqw7tx53"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/size/transparent=true
window/size/maximize_disabled=true
window/subwindows/embed_subwindows=false
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/per_pixel_transparency/allowed=true
window/vsync/vsync_mode=0

[editor]

run/main_run_args="-s"

[physics]

2d/run_on_separate_thread=true
common/physics_ticks_per_second=120
2d/physics_engine="Rapier2D"
3d/physics_engine="Jolt Physics"
2d/default_gravity=3000.0
2d/solver/solver_iterations=64

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
